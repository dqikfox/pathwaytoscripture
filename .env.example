# Copy this file to .env and fill in your values

# Session secret – generate a long random string
SESSION_SECRET=change_this_to_a_long_random_secret

# Stripe API keys (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE_KEY

# Base URL of the site (no trailing slash)
BASE_URL=http://localhost:3000

# Port
PORT=3000

# Admin registration code (used to create admin accounts)
ADMIN_CODE=change_this_admin_code
