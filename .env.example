# Copy this file to .env and fill in your values

# Session secret – generate a long random string
SESSION_SECRET=change_this_to_a_long_random_secret

# Production environment
NODE_ENV=development

# Reverse proxy hop count (GoDaddy Node.js Hosting should stay at 1)
TRUST_PROXY=1

# Session store driver: sqlite for durable local/VPS storage, memory for non-durable previews
SESSION_STORE=sqlite

# Optional writable data directory for VPS deployments
APP_DATA_DIR=./data

# Optional explicit SQLite file path
SQLITE_DB_PATH=

# Stripe API keys (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE_KEY

# Base URL of the site (no trailing slash)
BASE_URL=http://localhost:3000

# Port
PORT=3000

# Admin registration code (used to create admin accounts)
ADMIN_CODE=change_this_admin_code

# Optional comma-separated bootstrap admin emails
AUTO_ADMIN_EMAILS=

# Optional seed credentials
SEED_ADMIN_EMAIL=admin@pathwaytoscripture.org
SEED_ADMIN_PASSWORD=ChangeMe123!

# Optional Bitcoin checkout placeholders for /products
# Use a hosted checkout URL from your provider OR a direct wallet address.
BITCOIN_PAYMENT_LINK=
BITCOIN_ADDRESS=
