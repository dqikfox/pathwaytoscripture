<%- include('../partials/header') %>

<div class="container-fluid py-4">
  <div class="row">
    <div class="col-md-2 mb-4">
      <%- include('_sidebar', { active: 'transactions' }) %>
    </div>
    <div class="col-md-10">
      <h2 class="mb-4">Transaction History</h2>

      <div class="table-responsive card shadow-sm">
        <table class="table table-hover mb-0 align-middle">
          <thead class="table-light">
            <tr>
              <th>#</th>
              <th>Date</th>
              <th>Customer</th>
              <th>Description</th>
              <th>Type</th>
              <th>Amount</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% transactions.forEach(t => { %>
              <tr>
                <td class="text-muted small"><%= t.id %></td>
                <td class="small">
                  <%= new Date(t.created_at).toLocaleDateString('en-AU') %><br>
                  <span class="text-muted"><%= new Date(t.created_at).toLocaleTimeString('en-AU', { hour:'2-digit', minute:'2-digit' }) %></span>
                </td>
                <td>
                  <a href="/admin/customers/<%= t.user_id %>">
                    <%= t.first_name %> <%= t.last_name %>
                  </a>
                </td>
                <td><%= t.description || '—' %></td>
                <td><span class="badge bg-secondary"><%= t.type %></span></td>
                <td class="fw-bold text-primary">$<%= (t.amount_cents / 100).toFixed(2) %></td>
                <td>
                  <span class="badge <%= t.status === 'completed' ? 'bg-success' : 'bg-warning text-dark' %>">
                    <%= t.status %>
                  </span>
                </td>
              </tr>
            <% }) %>
            <% if (transactions.length === 0) { %>
              <tr><td colspan="7" class="text-center text-muted py-3">No transactions yet.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
