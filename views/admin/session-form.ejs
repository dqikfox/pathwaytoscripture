<%- include('../partials/header') %>

<div class="container-fluid py-4">
  <div class="row">
    <div class="col-md-2 mb-4">
      <%- include('_sidebar', { active: 'sessions' }) %>
    </div>
    <div class="col-md-10">
      <div class="row justify-content-center">
        <div class="col-lg-8">
          <h2 class="mb-4"><%= title %></h2>

          <%- include('../partials/errors') %>

          <form method="POST" action="<%= session ? '/admin/sessions/' + session.id + '/edit' : '/admin/sessions' %>">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <div class="card shadow-sm">
              <div class="card-body">
                <div class="row g-3">
                  <div class="col-12">
                    <label class="form-label">Session Title <span class="text-danger">*</span></label>
                    <input type="text" name="title" class="form-control"
                      value="<%= session ? session.title || '' : '' %>" required />
                  </div>
                  <div class="col-12">
                    <label class="form-label">Description</label>
                    <textarea name="description" class="form-control" rows="3"><%= session ? session.description || '' : '' %></textarea>
                  </div>
                  <div class="col-sm-6">
                    <label class="form-label">Facilitator</label>
                    <input type="text" name="facilitator" class="form-control"
                      value="<%= session ? session.facilitator || '' : '' %>" />
                  </div>
                  <div class="col-sm-6">
                    <label class="form-label">Price (AUD) <span class="text-danger">*</span></label>
                    <div class="input-group">
                      <span class="input-group-text">$</span>
                      <input type="number" name="price_dollars" class="form-control"
                        min="0" step="0.01" value="<%= session ? session.price_dollars || '99.00' : '99.00' %>" required />
                    </div>
                    <div class="form-text">Price includes GST (e.g. 99.00)</div>
                  </div>
                  <div class="col-sm-6">
                    <label class="form-label">Date <span class="text-danger">*</span></label>
                    <input type="date" name="session_date" class="form-control"
                      value="<%= session ? session.session_date || '' : '' %>" required />
                  </div>
                  <div class="col-sm-3">
                    <label class="form-label">Start Time <span class="text-danger">*</span></label>
                    <input type="time" name="session_time" class="form-control"
                      value="<%= session ? session.session_time || '' : '' %>" required />
                  </div>
                  <div class="col-sm-3">
                    <label class="form-label">Duration (mins) <span class="text-danger">*</span></label>
                    <input type="number" name="duration_mins" class="form-control"
                      min="1" value="<%= session ? session.duration_mins || 90 : 90 %>" required />
                  </div>
                  <div class="col-sm-6">
                    <label class="form-label">Location</label>
                    <input type="text" name="location" class="form-control"
                      value="<%= session ? session.location || '' : '' %>"
                      placeholder="e.g. St Mary's Church Hall" />
                  </div>
                  <div class="col-sm-6">
                    <label class="form-label">Online Meeting Link</label>
                    <input type="url" name="online_link" class="form-control"
                      value="<%= session ? session.online_link || '' : '' %>"
                      placeholder="https://zoom.us/..." />
                  </div>
                  <div class="col-sm-6">
                    <label class="form-label">Capacity (max attendees) <span class="text-danger">*</span></label>
                    <input type="number" name="capacity" class="form-control"
                      min="1" value="<%= session ? session.capacity || 20 : 20 %>" required />
                  </div>
                  <% if (session) { %>
                  <div class="col-sm-6">
                    <label class="form-label">Active</label><br>
                    <div class="form-check form-switch mt-1">
                      <input class="form-check-input" type="checkbox" name="is_active" value="1"
                        <%- session.is_active ? 'checked' : '' %> />
                      <label class="form-check-label">Session is visible to customers</label>
                    </div>
                  </div>
                  <% } %>
                </div>
              </div>
              <div class="card-footer bg-transparent d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                  <i class="bi bi-save"></i> <%= session ? 'Save Changes' : 'Create Session' %>
                </button>
                <a href="/admin/sessions" class="btn btn-outline-secondary">Cancel</a>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
