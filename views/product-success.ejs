<%- include('partials/header') %>

<div class="container py-5" style="max-width: 760px;">
  <div class="card shadow-sm border-success">
    <div class="card-body p-4">
      <div class="text-center mb-4">
        <i class="bi bi-check-circle-fill text-success" style="font-size: 3rem;"></i>
        <h2 class="mt-3 mb-1">Payment Successful</h2>
        <p class="text-muted mb-0">Thank you for your order. Your payment has been received.</p>
      </div>

      <% if (item) { %>
        <div class="row g-3 mb-3">
          <div class="col-md-8">
            <p class="text-uppercase text-muted small mb-1">Item</p>
            <h5 class="mb-0"><%= item.description || 'Product' %></h5>
          </div>
          <div class="col-md-4 text-md-end">
            <p class="text-uppercase text-muted small mb-1">Amount</p>
            <h5 class="mb-0 text-primary">$<%= (checkoutSession.amount_total / 100).toFixed(2) %> AUD</h5>
          </div>
        </div>
      <% } %>

      <div class="small text-muted mb-4">
        <div><strong>Reference:</strong> <%= checkoutSession.id %></div>
        <div><strong>Status:</strong> <%= checkoutSession.payment_status %></div>
      </div>

      <div class="d-flex gap-2 flex-wrap">
        <a href="/products" class="btn btn-primary">Back to Products</a>
        <a href="/dashboard" class="btn btn-outline-secondary">Go to Dashboard</a>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
