<%- include('partials/header') %>

<div class="container py-5" style="max-width: 860px;">
  <div class="card shadow-sm border-success">
    <div class="card-body p-4">
      <div class="text-center mb-4">
        <i class="bi bi-check-circle-fill text-success" style="font-size: 3rem;"></i>
        <h2 class="mt-3 mb-1">Order Confirmed</h2>
        <p class="text-muted mb-0">Thank you. Your order has been received and payment is confirmed.</p>
      </div>

      <div class="row g-3 mb-3">
        <div class="col-md-6"><strong>Order #:</strong> <%= order.id %></div>
        <div class="col-md-6"><strong>Payment:</strong> <%= order.payment_method %> (<%= order.payment_status %>)</div>
      </div>

      <div class="table-responsive mb-3">
        <table class="table table-sm">
          <thead><tr><th>Item</th><th>Qty</th><th class="text-end">Line Total</th></tr></thead>
          <tbody>
            <% items.forEach(i => { %>
              <tr>
                <td><%= i.product_name %></td>
                <td><%= i.quantity %></td>
                <td class="text-end">$<%= (i.line_total_cents / 100).toFixed(2) %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <div class="d-flex justify-content-between fs-5 mb-4"><span>Total Paid</span><strong>$<%= (order.total_cents / 100).toFixed(2) %></strong></div>

      <div class="d-flex gap-2 flex-wrap">
        <a href="/products" class="btn btn-primary">Back to Store</a>
        <a href="/products/orders/<%= order.id %>" class="btn btn-outline-secondary">View Order</a>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
