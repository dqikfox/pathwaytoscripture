<%- include('partials/header') %>

<!-- Hero Section -->
<section class="hero-section text-white d-flex align-items-center">
  <div class="container position-relative hero-shell">
    <div class="row align-items-center g-5">
      <div class="col-lg-8 text-center text-lg-start">
        <div class="hero-kicker-wrap mb-3">
          <span class="hero-kicker">Catholic Bible Study</span>
          <span class="hero-kicker-divider" aria-hidden="true"></span>
          <span class="hero-kicker-sub">Scripture, prayer, and fellowship</span>
        </div>
        <img src="/images/pw2s-logo.png" alt="Pathway to Scripture" class="hero-logo" />
        <p class="slogan mb-2 fst-italic text-warning fs-5">Modern study. Ancient wisdom.</p>
        <p class="lead mb-4 hero-copy">
          Join our guided Catholic Bible study sessions and deepen your understanding
          of God's Word in a warm, welcoming community.
        </p>
        <div class="d-flex gap-3 justify-content-center justify-content-lg-start flex-wrap">
          <a href="/sessions" class="btn btn-warning btn-lg fw-semibold">
            <i class="bi bi-book-half"></i> View Sessions
          </a>
          <% if (!locals.user) { %>
            <a href="/register" class="btn btn-outline-light btn-lg">
              <i class="bi bi-person-plus"></i> Create Account
            </a>
          <% } else { %>
            <a href="/dashboard" class="btn btn-outline-light btn-lg">
              <i class="bi bi-speedometer2"></i> My Dashboard
            </a>
          <% } %>
        </div>
        <div class="hero-badges mt-4 d-flex justify-content-center justify-content-lg-start flex-wrap gap-2">
          <span class="badge hero-pill">Sacred Heart</span>
          <span class="badge hero-pill">Rosary</span>
          <span class="badge hero-pill">Cathedral Light</span>
        </div>
        <p class="mt-4 hero-price">
          <a href="/register" class="btn btn-warning btn-lg fw-semibold px-4">
            Start Your Journey Here
          </a>
        </p>
      </div>
    </div>

    <div class="row g-3 hero-icons mt-4 mt-lg-5">
      <div class="col-md-4">
        <div class="hero-icon-card">
          <img src="/images/retro-sacred-heart.svg" alt="Sacred Heart icon" class="hero-icon-image" />
          <div>
            <h3 class="hero-icon-title mb-1">Sacred Heart</h3>
            <p class="hero-icon-copy mb-0">Christ's love at the centre of the journey.</p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="hero-icon-card">
          <img src="/images/retro-rosary.svg" alt="Rosary icon" class="hero-icon-image" />
          <div>
            <h3 class="hero-icon-title mb-1">Rosary Devotion</h3>
            <p class="hero-icon-copy mb-0">Prayerful rhythm and Marian contemplation.</p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="hero-icon-card">
          <img src="/images/retro-cathedral-window.svg" alt="Cathedral window icon" class="hero-icon-image" />
          <div>
            <h3 class="hero-icon-title mb-1">Cathedral Light</h3>
            <p class="hero-icon-copy mb-0">Scripture reflected in stained-glass splendour.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Mission -->
<section class="py-5">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-8 text-center">
        <h2 class="section-title mb-4">Our Mission</h2>
        <p class="lead text-muted">
          At Pathway to Scripture, we offer a Bible study experience that is modern in its approach yet deeply rooted in timeless Christian tradition. We believe the Word of God speaks powerfully into every generation, and our goal is to present Scripture with clarity, reverence, and practical guidance that meets people right where they are today.
        </p>
        <p class="text-muted">
          We combine solid biblical teaching with accessible, real‑world application — helping believers not only understand Scripture, but live it out with confidence, purpose, and faith. Whether you are new to the Bible or seeking to grow further, Pathway to Scripture is here to support your journey with teaching that is faithful, clear, and transformative.
        </p>
        <p class="fw-semibold text-primary mt-3">
          Our mission is simple: to guide every believer into deeper understanding, stronger spiritual growth, and a confident walk in the Word of God.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- Features -->
<section class="py-5 bg-light">
  <div class="container">
    <div class="row text-center gy-4">
      <div class="col-md-4">
        <div class="feature-icon mb-3"><i class="bi bi-book text-primary fs-1"></i></div>
        <h4>Deep Scripture Study</h4>
        <p class="text-muted">Explore the Old and New Testaments with knowledgeable Catholic facilitators who bring the texts to life.</p>
      </div>
      <div class="col-md-4">
        <div class="feature-icon mb-3"><i class="bi bi-people text-primary fs-1"></i></div>
        <h4>Community &amp; Fellowship</h4>
        <p class="text-muted">Connect with fellow believers in a supportive group environment that encourages growth and reflection.</p>
      </div>
      <div class="col-md-4">
        <div class="feature-icon mb-3"><i class="bi bi-calendar-check text-primary fs-1"></i></div>
        <h4>Flexible Scheduling</h4>
        <p class="text-muted">Book sessions that suit your schedule. View upcoming dates and secure your spot online in minutes.</p>
      </div>
    </div>
  </div>
</section>

<!-- Sacred Retro Gallery -->
<section class="retro-gallery py-5">
  <div class="container">
    <div class="text-center mb-4">
      <p class="text-uppercase retro-kicker mb-2">Catholic Heritage</p>
      <h2 class="retro-gallery-title mb-3">Sacred Imagery in a Vintage Style</h2>
      <p class="retro-gallery-copy mx-auto">
        A small visual collection inspired by classic church art, warm tones, and timeless Catholic symbolism.
      </p>
    </div>

    <div class="row g-4 justify-content-center">
      <div class="col-md-6 col-lg-4">
        <article class="retro-frame h-100">
          <img
            src="/images/retro-cathedral-window.svg"
            class="img-fluid retro-image"
            alt="Vintage stained-glass cathedral window with a gold cross"
            loading="lazy"
          />
          <div class="retro-caption-wrap">
            <h3 class="retro-caption-title">Cathedral Light</h3>
            <p class="retro-caption-text mb-0">A stained-glass tribute to contemplative prayer and reverence.</p>
          </div>
        </article>
      </div>

      <div class="col-md-6 col-lg-4">
        <article class="retro-frame h-100">
          <img
            src="/images/retro-sacred-heart.svg"
            class="img-fluid retro-image"
            alt="Retro sacred heart motif with a cross and rays"
            loading="lazy"
          />
          <div class="retro-caption-wrap">
            <h3 class="retro-caption-title">Sacred Heart</h3>
            <p class="retro-caption-text mb-0">A classic symbol of Christ's love, rendered in a sepia palette.</p>
          </div>
        </article>
      </div>

      <div class="col-md-6 col-lg-4">
        <article class="retro-frame h-100">
          <img
            src="/images/retro-rosary.svg"
            class="img-fluid retro-image"
            alt="Stylized rosary beads and cross on a textured vintage background"
            loading="lazy"
          />
          <div class="retro-caption-wrap">
            <h3 class="retro-caption-title">Rosary Devotion</h3>
            <p class="retro-caption-text mb-0">A visual nod to meditation, rhythm, and Marian tradition.</p>
          </div>
        </article>
      </div>
    </div>
  </div>
</section>

<!-- Upcoming Sessions Preview -->
<% if (upcomingSessions && upcomingSessions.length > 0) { %>
<section class="py-5">
  <div class="container">
    <h2 class="text-center mb-4 section-title">Upcoming Bible Study Sessions</h2>
    <div class="row gy-4">
      <% upcomingSessions.forEach(s => { %>
        <div class="col-md-4">
          <div class="card h-100 shadow-sm session-card">
            <div class="card-body">
              <h5 class="card-title text-primary"><%= s.title %></h5>
              <p class="text-muted small mb-2">
                <i class="bi bi-calendar3"></i>
                <%= new Date(s.session_date + 'T' + s.session_time).toLocaleDateString('en-AU', { weekday:'long', year:'numeric', month:'long', day:'numeric' }) %>
                &nbsp;<i class="bi bi-clock ms-1"></i> <%= s.session_time.substring(0,5) %>
              </p>
              <% if (s.location) { %>
                <p class="text-muted small mb-2"><i class="bi bi-geo-alt"></i> <%= s.location %></p>
              <% } %>
              <p class="card-text small text-muted"><%= s.description ? s.description.substring(0, 100) + (s.description.length > 100 ? '…' : '') : '' %></p>
              <div class="d-flex justify-content-between align-items-center mt-3">
                <span class="fw-bold text-primary">$<%= (s.price_cents / 100).toFixed(2) %> <small class="text-muted fw-normal">inc. GST</small></span>
                <span class="badge <%= s.capacity - s.spots_taken > 5 ? 'bg-success' : (s.capacity - s.spots_taken > 0 ? 'bg-warning text-dark' : 'bg-danger') %>">
                  <%= s.capacity - s.spots_taken > 0 ? (s.capacity - s.spots_taken) + ' spots left' : 'Full' %>
                </span>
              </div>
            </div>
            <div class="card-footer bg-transparent">
              <a href="/sessions/<%= s.id %>" class="btn btn-primary w-100">Book Now</a>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
    <div class="text-center mt-4">
      <a href="/sessions" class="btn btn-outline-primary">See All Sessions <i class="bi bi-arrow-right"></i></a>
    </div>
  </div>
</section>
<% } %>

<!-- CTA -->
<section class="py-5 bg-primary text-white text-center">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-6">
        <h3>Ready to begin your journey?</h3>
        <p class="lead opacity-75 mb-4">Create a free account to register and book Bible study sessions.</p>
        <a href="/register" class="btn btn-warning btn-lg fw-semibold">Get Started Today</a>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
