<%- include('partials/header') %>

<div class="container py-5" style="max-width: 980px;">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Your Cart</h1>
    <a href="/products" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Continue Shopping</a>
  </div>

  <%- include('partials/flash') %>

  <% if (cartSummary.items.length === 0) { %>
    <div class="alert alert-info">Your cart is empty. Browse the products page to add items.</div>
  <% } else { %>
    <div class="table-responsive card shadow-sm mb-4">
      <table class="table align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Item</th>
            <th style="width: 140px;">Quantity</th>
            <th class="text-end">Unit Price</th>
            <th class="text-end">Line Total</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% cartSummary.items.forEach(item => { %>
            <tr>
              <td>
                <strong><%= item.name %></strong><br />
                <small class="text-muted"><%= item.category %></small>
              </td>
              <td>
                <form method="POST" action="/products/cart/update" class="d-flex gap-2">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <input type="hidden" name="product_id" value="<%= item.product_id %>" />
                  <input type="number" name="quantity" min="1" max="10" value="<%= item.quantity %>" class="form-control form-control-sm" />
                  <button class="btn btn-sm btn-outline-primary" type="submit">Update</button>
                </form>
              </td>
              <td class="text-end">$<%= (item.unit_price_cents / 100).toFixed(2) %></td>
              <td class="text-end fw-semibold">$<%= (item.line_total_cents / 100).toFixed(2) %></td>
              <td class="text-end">
                <form method="POST" action="/products/cart/remove">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <input type="hidden" name="product_id" value="<%= item.product_id %>" />
                  <button class="btn btn-sm btn-outline-danger" type="submit">Remove</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div class="card shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between mb-2"><span>Subtotal</span><strong>$<%= (cartSummary.subtotal_cents / 100).toFixed(2) %></strong></div>
        <div class="d-flex justify-content-between mb-2"><span>Shipping</span><strong>$<%= (cartSummary.shipping_cents / 100).toFixed(2) %></strong></div>
        <div class="d-flex justify-content-between text-muted small mb-3"><span>Tax</span><span>Included in prices</span></div>
        <hr />
        <div class="d-flex justify-content-between fs-5"><span>Total</span><strong>$<%= (cartSummary.total_cents / 100).toFixed(2) %></strong></div>
        <div class="mt-3 d-grid d-md-flex justify-content-md-end">
          <a href="/products/checkout" class="btn btn-primary btn-lg">Proceed to Checkout</a>
        </div>
      </div>
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>
