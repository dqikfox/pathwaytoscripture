<%- include('partials/header') %>

<div class="container py-5">
  <div class="row">
    <!-- Sidebar -->
    <div class="col-md-3 mb-4">
      <div class="card shadow-sm">
        <div class="card-body text-center">
          <div class="mb-2">
            <i class="bi bi-person-circle text-primary" style="font-size: 3rem;"></i>
          </div>
          <h6 class="fw-bold mb-0"><%= pageUser.first_name %> <%= pageUser.last_name %></h6>
          <small class="text-muted"><%= pageUser.email %></small>
          <hr />
          <p class="mb-1 small text-muted">Account Balance</p>
          <p class="fw-bold text-primary fs-5 mb-0">$<%= pageUser.account_balance.toFixed(2) %></p>
        </div>
        <div class="list-group list-group-flush">
          <a href="/dashboard" class="list-group-item list-group-item-action active">
            <i class="bi bi-speedometer2 me-2"></i> Dashboard
          </a>
          <a href="/dashboard/profile" class="list-group-item list-group-item-action">
            <i class="bi bi-person me-2"></i> My Profile
          </a>
          <a href="/sessions" class="list-group-item list-group-item-action">
            <i class="bi bi-book me-2"></i> Book a Session
          </a>
          <a href="/logout" class="list-group-item list-group-item-action text-danger">
            <i class="bi bi-box-arrow-right me-2"></i> Sign Out
          </a>
        </div>
      </div>
    </div>

    <!-- Main content -->
    <div class="col-md-9">
      <%- include('partials/flash') %>

      <!-- My Bookings -->
      <h4 class="section-title mb-3">My Session Bookings</h4>

      <% if (bookings.length === 0) { %>
        <div class="alert alert-info mb-4">
          You haven't booked any sessions yet.
          <a href="/sessions">Browse available sessions</a>.
        </div>
      <% } else { %>
        <div class="table-responsive mb-4">
          <table class="table table-hover align-middle">
            <thead class="table-light">
              <tr>
                <th>Session</th>
                <th>Date</th>
                <th>Status</th>
                <th>Amount</th>
              </tr>
            </thead>
            <tbody>
              <% bookings.forEach(b => { %>
                <tr>
                  <td><strong><%= b.title %></strong><br>
                    <small class="text-muted"><%= b.location || '' %></small>
                  </td>
                  <td class="small">
                    <%= new Date(b.session_date + 'T' + b.session_time).toLocaleDateString('en-AU', { day:'numeric', month:'short', year:'numeric' }) %>
                    <br><%= b.session_time.substring(0,5) %>
                  </td>
                  <td>
                    <span class="badge <%= b.payment_status === 'paid' ? 'bg-success' : 'bg-warning text-dark' %>">
                      <%= b.payment_status === 'paid' ? 'Confirmed' : 'Pending' %>
                    </span>
                  </td>
                  <td class="fw-bold">$<%= (b.amount_cents / 100).toFixed(2) %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>

      <!-- Transaction History -->
      <h4 class="section-title mb-3">Transaction History</h4>

      <% if (transactions.length === 0) { %>
        <div class="alert alert-info">No transactions yet.</div>
      <% } else { %>
        <div class="table-responsive">
          <table class="table table-hover align-middle">
            <thead class="table-light">
              <tr>
                <th>Date</th>
                <th>Description</th>
                <th>Type</th>
                <th>Amount</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <% transactions.forEach(t => { %>
                <tr>
                  <td class="small text-muted">
                    <%= new Date(t.created_at).toLocaleDateString('en-AU', { day:'numeric', month:'short', year:'numeric' }) %>
                  </td>
                  <td><%= t.description || '—' %></td>
                  <td><span class="badge bg-secondary"><%= t.type %></span></td>
                  <td class="fw-bold text-primary">$<%= (t.amount_cents / 100).toFixed(2) %></td>
                  <td>
                    <span class="badge <%= t.status === 'completed' ? 'bg-success' : 'bg-warning text-dark' %>">
                      <%= t.status %>
                    </span>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
