<%- include('partials/header') %>

<div class="container py-5" style="max-width: 520px;">
  <div class="card shadow-sm">
    <div class="card-body p-4">
      <div class="text-center mb-4">
        <span class="text-primary display-6">✝</span>
        <h2 class="mt-2">Create Your Account</h2>
        <p class="text-muted small">Register to book Bible study sessions</p>
      </div>

      <%- include('partials/errors') %>

      <form method="POST" action="/register" novalidate>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="row g-3">
          <div class="col-6">
            <label class="form-label">First Name <span class="text-danger">*</span></label>
            <input type="text" name="first_name" class="form-control"
              value="<%= typeof old !== 'undefined' ? old.first_name || '' : '' %>" required />
          </div>
          <div class="col-6">
            <label class="form-label">Last Name <span class="text-danger">*</span></label>
            <input type="text" name="last_name" class="form-control"
              value="<%= typeof old !== 'undefined' ? old.last_name || '' : '' %>" required />
          </div>
          <div class="col-12">
            <label class="form-label">Email Address <span class="text-danger">*</span></label>
            <input type="email" name="email" class="form-control"
              value="<%= typeof old !== 'undefined' ? old.email || '' : '' %>" required />
          </div>
          <div class="col-12">
            <label class="form-label">Phone Number</label>
            <input type="tel" name="phone" class="form-control"
              value="<%= typeof old !== 'undefined' ? old.phone || '' : '' %>"
              placeholder="e.g. 04XX XXX XXX" />
          </div>
          <div class="col-12">
            <label class="form-label">Street Address</label>
            <input type="text" name="address_line1" class="form-control"
              value="<%= typeof old !== 'undefined' ? old.address_line1 || '' : '' %>"
              placeholder="Street address" />
          </div>
          <div class="col-12">
            <input type="text" name="address_line2" class="form-control"
              value="<%= typeof old !== 'undefined' ? old.address_line2 || '' : '' %>"
              placeholder="Apt, suite, unit (optional)" />
          </div>
          <div class="col-5">
            <label class="form-label">Suburb</label>
            <input type="text" name="suburb" class="form-control"
              value="<%= typeof old !== 'undefined' ? old.suburb || '' : '' %>" />
          </div>
          <div class="col-4">
            <label class="form-label">State</label>
            <select name="state" class="form-select">
              <option value="">—</option>
              <% ['ACT','NSW','NT','QLD','SA','TAS','VIC','WA'].forEach(s => { %>
                <option value="<%= s %>" <%- (typeof old !== 'undefined' && old.state === s) ? 'selected' : '' %>><%= s %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-3">
            <label class="form-label">Postcode</label>
            <input type="text" name="postcode" class="form-control" maxlength="4"
              value="<%= typeof old !== 'undefined' ? old.postcode || '' : '' %>" />
          </div>
          <div class="col-12">
            <label class="form-label">Password <span class="text-danger">*</span></label>
            <input type="password" name="password" class="form-control"
              minlength="8" required placeholder="Minimum 8 characters" />
          </div>
          <div class="col-12">
            <label class="form-label">Confirm Password <span class="text-danger">*</span></label>
            <input type="password" name="password_confirm" class="form-control" required />
          </div>
          <div class="col-12">
            <button type="submit" class="btn btn-primary w-100 fw-semibold">
              <i class="bi bi-person-plus"></i> Create Account
            </button>
          </div>
        </div>
      </form>

      <p class="text-center text-muted mt-3 small">
        Already have an account? <a href="/login">Sign in</a>
      </p>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
