<%- include('partials/header') %>

<div class="container py-5" style="max-width: 860px;">
  <div class="card shadow-sm border-warning">
    <div class="card-body p-4">
      <h2 class="mb-3"><i class="bi bi-currency-bitcoin"></i> Bitcoin Payment</h2>
      <p class="text-muted">Order #<strong><%= order.id %></strong> has been created and is awaiting Bitcoin payment confirmation.</p>

      <% if (bitcoinPaymentLink) { %>
        <a href="<%= bitcoinPaymentLink %>" target="_blank" rel="noopener" class="btn btn-dark mb-3">Open Bitcoin Checkout</a>
      <% } %>

      <% if (bitcoinAddress) { %>
        <label class="form-label fw-semibold">Bitcoin Wallet Address</label>
        <div class="input-group mb-3">
          <input type="text" class="form-control" id="btcAddr" readonly value="<%= bitcoinAddress %>" />
          <button class="btn btn-outline-secondary" id="copyBtc" type="button">Copy</button>
        </div>
      <% } else { %>
        <div class="alert alert-warning">Bitcoin address is not configured yet. Please contact support.</div>
      <% } %>

      <div class="table-responsive mt-3">
        <table class="table table-sm mb-0">
          <thead><tr><th>Item</th><th>Qty</th><th class="text-end">Line Total</th></tr></thead>
          <tbody>
            <% items.forEach(i => { %>
              <tr>
                <td><%= i.product_name %></td>
                <td><%= i.quantity %></td>
                <td class="text-end">$<%= (i.line_total_cents / 100).toFixed(2) %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <div class="d-flex justify-content-between fs-5 mt-3"><span>Amount Due</span><strong>$<%= (order.total_cents / 100).toFixed(2) %> AUD</strong></div>

      <p class="small text-muted mt-3 mb-0">After payment, your order status will be updated by admin confirmation.</p>
    </div>
  </div>
</div>

<script>
  (function () {
    const btn = document.getElementById('copyBtc');
    const input = document.getElementById('btcAddr');
    if (!btn || !input) return;
    btn.addEventListener('click', async () => {
      try { await navigator.clipboard.writeText(input.value); }
      catch (_) { input.select(); document.execCommand('copy'); }
      btn.textContent = 'Copied';
      setTimeout(() => { btn.textContent = 'Copy'; }, 1200);
    });
  })();
</script>

<%- include('partials/footer') %>
