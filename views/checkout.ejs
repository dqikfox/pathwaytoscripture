<%- include('partials/header') %>

<div class="container py-5" style="max-width: 1100px;">
  <h1 class="mb-4">Checkout</h1>
  <%- include('partials/flash') %>

  <div class="row g-4">
    <div class="col-lg-7">
      <div class="card shadow-sm">
        <div class="card-body">
          <h5 class="mb-3">Billing & Shipping Details</h5>
          <form id="checkoutForm" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <div class="row g-3">
              <div class="col-12">
                <label class="form-label">Full Name</label>
                <input required class="form-control" name="customer_name" value="<%= checkoutCustomer.customer_name %>" />
              </div>
              <div class="col-md-6">
                <label class="form-label">Email</label>
                <input required type="email" class="form-control" name="customer_email" value="<%= checkoutCustomer.customer_email %>" />
              </div>
              <div class="col-md-6">
                <label class="form-label">Phone</label>
                <input class="form-control" name="customer_phone" value="<%= checkoutCustomer.customer_phone %>" />
              </div>
              <div class="col-12">
                <label class="form-label">Address Line 1</label>
                <input required class="form-control" name="address_line1" value="<%= checkoutCustomer.address_line1 %>" />
              </div>
              <div class="col-12">
                <label class="form-label">Address Line 2</label>
                <input class="form-control" name="address_line2" value="<%= checkoutCustomer.address_line2 %>" />
              </div>
              <div class="col-md-4">
                <label class="form-label">Suburb</label>
                <input class="form-control" name="suburb" value="<%= checkoutCustomer.suburb %>" />
              </div>
              <div class="col-md-4">
                <label class="form-label">State</label>
                <input class="form-control" name="state" value="<%= checkoutCustomer.state %>" />
              </div>
              <div class="col-md-4">
                <label class="form-label">Postcode</label>
                <input class="form-control" name="postcode" value="<%= checkoutCustomer.postcode %>" />
              </div>
              <div class="col-12">
                <label class="form-label">Country</label>
                <input class="form-control" name="country" value="<%= checkoutCustomer.country %>" />
              </div>
            </div>

            <hr class="my-4" />
            <div class="form-check mb-3">
              <input class="form-check-input" type="checkbox" value="1" id="acceptTerms" name="accept_terms" required>
              <label class="form-check-label" for="acceptTerms">
                I agree to the <a href="/legal/terms" target="_blank" rel="noopener">Terms of Use</a>,
                <a href="/legal/privacy" target="_blank" rel="noopener">Privacy Policy</a>,
                <a href="/legal/refunds" target="_blank" rel="noopener">Refund Policy</a>, and
                <a href="/legal/shipping" target="_blank" rel="noopener">Shipping Policy</a>.
              </label>
            </div>

            <div class="d-flex flex-wrap gap-2">
              <button type="submit" class="btn btn-primary" formaction="/products/checkout/card">
                <i class="bi bi-credit-card"></i> Pay with Card
              </button>
              <button type="submit" class="btn btn-dark" formaction="/products/checkout/bitcoin">
                <i class="bi bi-currency-bitcoin"></i> Pay with Bitcoin
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <div class="col-lg-5">
      <div class="card shadow-sm">
        <div class="card-body">
          <h5 class="mb-3">Order Summary</h5>
          <% cartSummary.items.forEach(item => { %>
            <div class="d-flex justify-content-between align-items-start mb-2">
              <div>
                <strong><%= item.name %></strong>
                <div class="small text-muted">Qty <%= item.quantity %></div>
              </div>
              <div>$<%= (item.line_total_cents / 100).toFixed(2) %></div>
            </div>
          <% }) %>
          <hr />
          <div class="d-flex justify-content-between mb-2"><span>Subtotal</span><strong>$<%= (cartSummary.subtotal_cents / 100).toFixed(2) %></strong></div>
          <div class="d-flex justify-content-between mb-2"><span>Shipping</span><strong>$<%= (cartSummary.shipping_cents / 100).toFixed(2) %></strong></div>
          <div class="d-flex justify-content-between small text-muted mb-3"><span>Tax</span><span>Included</span></div>
          <div class="d-flex justify-content-between fs-5"><span>Total</span><strong>$<%= (cartSummary.total_cents / 100).toFixed(2) %></strong></div>

          <p class="small text-muted mt-3 mb-0">Terms version: <%= termsVersion %></p>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
