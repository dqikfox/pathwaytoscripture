<%- include('partials/header') %>

<div class="container py-5" style="max-width: 920px;">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Order #<%= order.id %></h1>
    <a href="/products" class="btn btn-outline-secondary">Back to Store</a>
  </div>

  <div class="card shadow-sm mb-3">
    <div class="card-body">
      <div class="row g-3">
        <div class="col-md-4"><strong>Payment Method:</strong> <%= order.payment_method %></div>
        <div class="col-md-4"><strong>Payment Status:</strong> <%= order.payment_status %></div>
        <div class="col-md-4"><strong>Fulfillment:</strong> <%= order.fulfillment_status %></div>
        <div class="col-md-6"><strong>Customer:</strong> <%= order.customer_name %> (<%= order.customer_email %>)</div>
        <div class="col-md-6"><strong>Date:</strong> <%= order.created_at %></div>
      </div>
    </div>
  </div>

  <div class="card shadow-sm">
    <div class="card-body">
      <h5 class="mb-3">Items</h5>
      <div class="table-responsive">
        <table class="table table-sm">
          <thead><tr><th>Item</th><th>Qty</th><th class="text-end">Unit</th><th class="text-end">Line Total</th></tr></thead>
          <tbody>
            <% items.forEach(i => { %>
              <tr>
                <td><%= i.product_name %></td>
                <td><%= i.quantity %></td>
                <td class="text-end">$<%= (i.unit_price_cents / 100).toFixed(2) %></td>
                <td class="text-end">$<%= (i.line_total_cents / 100).toFixed(2) %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <div class="d-flex justify-content-between fs-5 mt-3"><span>Total</span><strong>$<%= (order.total_cents / 100).toFixed(2) %></strong></div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
