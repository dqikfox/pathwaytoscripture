<%- include('partials/header') %>

<div class="container py-5">
  <h1 class="mb-2 section-title">Bible Study Sessions</h1>
  <p class="text-muted mb-4">Join one of our upcoming guided sessions. All sessions are $99 inc. GST.</p>

  <% if (sessions.length === 0) { %>
    <div class="alert alert-info">No upcoming sessions are currently scheduled. Please check back soon.</div>
  <% } else { %>
    <div class="row gy-4">
      <% sessions.forEach(s => { %>
        <div class="col-md-6 col-lg-4">
          <div class="card h-100 shadow-sm session-card">
            <div class="card-header bg-primary text-white">
              <small><i class="bi bi-calendar3"></i>
                <%= new Date(s.session_date + 'T' + s.session_time).toLocaleDateString('en-AU', { weekday:'short', year:'numeric', month:'short', day:'numeric' }) %>
                &nbsp;at&nbsp;<%= s.session_time.substring(0,5) %>
              </small>
            </div>
            <div class="card-body">
              <h5 class="card-title text-primary"><%= s.title %></h5>
              <% if (s.facilitator) { %>
                <p class="text-muted small mb-1"><i class="bi bi-person"></i> <%= s.facilitator %></p>
              <% } %>
              <% if (s.location) { %>
                <p class="text-muted small mb-1"><i class="bi bi-geo-alt"></i> <%= s.location %></p>
              <% } %>
              <p class="text-muted small mb-2"><i class="bi bi-clock"></i> <%= s.duration_mins %> minutes</p>
              <p class="card-text small text-muted">
                <%= s.description ? s.description.substring(0, 120) + (s.description.length > 120 ? '…' : '') : '' %>
              </p>
            </div>
            <div class="card-footer bg-transparent d-flex justify-content-between align-items-center">
              <span class="fw-bold text-primary fs-5">$<%= (s.price_cents / 100).toFixed(2) %></span>
              <div class="d-flex align-items-center gap-2">
                <% const spots = s.capacity - s.spots_taken; %>
                <span class="badge <%= spots > 5 ? 'bg-success' : (spots > 0 ? 'bg-warning text-dark' : 'bg-danger') %>">
                  <%= spots > 0 ? spots + ' spots left' : 'Fully Booked' %>
                </span>
                <% if (spots > 0) { %>
                  <a href="/sessions/<%= s.id %>" class="btn btn-primary btn-sm">Book</a>
                <% } else { %>
                  <button class="btn btn-secondary btn-sm" disabled>Full</button>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>

  <% if (!locals.user) { %>
    <div class="alert alert-info mt-4">
      <i class="bi bi-info-circle"></i>
      <a href="/login">Sign in</a> or <a href="/register">create a free account</a> to book a session.
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>
