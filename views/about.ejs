<%- include('partials/header') %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <h1 class="section-title mb-4">About Pathway to Scripture</h1>

      <div class="row gy-4 align-items-center">
        <div class="col-md-6">
          <p class="lead">
            Pathway to Scripture is a Catholic ministry dedicated to helping the faithful
            deepen their understanding of Sacred Scripture through guided group study.
          </p>
          <p>
            Our facilitators bring years of theological study and pastoral experience to
            each session, creating a rich environment for learning, prayer, and community.
          </p>
          <p>
            Whether you are new to Bible study or have been exploring the Scriptures for
            years, our sessions offer fresh insights into both the Old and New Testaments,
            always in the light of Catholic teaching and tradition.
          </p>
        </div>
        <div class="col-md-6 text-center">
          <span class="text-primary" style="font-size: 8rem; line-height:1;">✝</span>
          <p class="text-muted mt-2 fst-italic">
            "Your word is a lamp for my feet, a light on my path."
            <br>— Psalm 119:105
          </p>
        </div>
      </div>

      <hr class="my-5" />

      <h3 class="mb-3">What We Offer</h3>
      <div class="row gy-3">
        <div class="col-sm-6">
          <div class="d-flex gap-3">
            <i class="bi bi-book-half text-primary fs-4 flex-shrink-0"></i>
            <div>
              <h6>In-Depth Scripture Study</h6>
              <p class="text-muted small">Verse-by-verse examination of Scripture books with historical and theological context.</p>
            </div>
          </div>
        </div>
        <div class="col-sm-6">
          <div class="d-flex gap-3">
            <i class="bi bi-chat-dots text-primary fs-4 flex-shrink-0"></i>
            <div>
              <h6>Group Discussion</h6>
              <p class="text-muted small">Open and guided discussion in a respectful, faith-filled environment.</p>
            </div>
          </div>
        </div>
        <div class="col-sm-6">
          <div class="d-flex gap-3">
            <i class="bi bi-camera-video text-primary fs-4 flex-shrink-0"></i>
            <div>
              <h6>Online &amp; In-Person</h6>
              <p class="text-muted small">Sessions available both at our parish location and via online video.</p>
            </div>
          </div>
        </div>
        <div class="col-sm-6">
          <div class="d-flex gap-3">
            <i class="bi bi-currency-dollar text-primary fs-4 flex-shrink-0"></i>
            <div>
              <h6>$99 inc. GST per Session</h6>
              <p class="text-muted small">Simple, transparent pricing. Book and pay securely online.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-5 text-center">
        <a href="/sessions" class="btn btn-primary btn-lg me-3">
          <i class="bi bi-calendar3"></i> View Sessions
        </a>
        <a href="/contact" class="btn btn-outline-primary btn-lg">
          <i class="bi bi-envelope"></i> Get in Touch
        </a>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
