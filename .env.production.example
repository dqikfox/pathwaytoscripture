# ─── Pathway to Scripture – Production Environment Variables ─────────────────
# Copy this file to .env on your GoDaddy server and fill in the real values.
# NEVER commit the filled-in .env file to source control.

# ─── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── Session ──────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=CHANGE_ME_to_a_random_64_byte_hex_string

# ─── Database ─────────────────────────────────────────────────────────────────
# Absolute path to the directory where the SQLite database and session files
# will be stored.  Choose a directory OUTSIDE the web root so it is not
# publicly accessible.  Example for GoDaddy cPanel:
#   /home/<cpanel_username>/pathwaytoscripture_data
APP_DATA_DIR=/home/YOUR_CPANEL_USERNAME/pathwaytoscripture_data

# Optional: override the full path to the SQLite database file.
# If omitted, defaults to <APP_DATA_DIR>/pathwaytoscripture.db
# SQLITE_DB_PATH=/home/YOUR_CPANEL_USERNAME/pathwaytoscripture_data/pathwaytoscripture.db

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Live keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_STRIPE_PUBLISHABLE_KEY

# Webhook secret from https://dashboard.stripe.com/webhooks
# Configure the webhook endpoint as: https://pathwaytoscripture.org/bookings/webhook
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET
